{
  "name": "hypermd",
  "version": "0.3.11",
  "description": "A full-featured Markdown editor, breaks the wall between writing and preview.",
  "main": "./dist/hypermd.umd.js",
  "module": "./dist/hypermd.es.js",
  "types": "./dist/everything.d.ts",
  "exports": {
    ".": {
      "types": "./dist/everything.d.ts",
      "import": "./dist/hypermd.es.js",
      "require": "./dist/hypermd.umd.js"
    },
    "./core": {
      "types": "./dist/core/core.d.ts",
      "import": "./dist/core/core.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build_css && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,scss}\"",
    "build_css": "node dev/build-css.js",
    "build_doc": "cd dev/docgen && tsc && node ../tmp/index.js",
    "pretest": "cd test && tsc && node tools/prepare",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "markdown",
    "codemirror",
    "wysiwyg"
  ],
  "homepage": "https://laobubu.net/HyperMD/",
  "author": "laobubu <laobubu@gmail.com> (http://laobubu.net)",
  "license": "MIT",
  "devDependencies": {
    "@types/codemirror": "^0.0.56",
    "codemirror": "^5.65.20",
    "eslint": "^9.39.2",
    "glob": "^13.0.0",
    "prettier": "^3.7.4",
    "sass": "^1.97.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "codemirror": "^5.37.0"
  },
  "optionalDependencies": {
    "emojione": "^3.1.6",
    "flowchart.js": "^1.11.2",
    "katex": "^0.10.0-alpha",
    "marked": "^0.4.0",
    "mathjax": "^2.7.0",
    "mermaid": "^8.0.0-rc.8",
    "turndown": "^4.0.1",
    "turndown-plugin-gfm": "^1.0.1",
    "twemoji": "^11.0.0"
  }
}
